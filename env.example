##  Edit this file and save it as ".env"

## Server Endpoints
AUTH_SERVER=api.app.shortcut.com
API_SERVER=api.app.shortcut.com

## Debugging
#
# DEBUG_LEVEL=0 -> no HTTP debug logs
# DEBUG_LEVEL=1 -> HTTP logs with body/headers/query redacted
# DEBUG_LEVEL=2 -> verbose HTTP logs (full body/query, but still strips authorization and cookie)
# DEBUG_LEVEL=3 -> dump everything, including all headers (authorization, cookie, etc.)
#
DEBUG_LEVEL=0

## Local development
#
# Turn this on if you want to skip Auth:
#   
# Set to false if you want to skip auth
#  ENABLE_OAUTH_PROTECTED_RESOURCE_METADATA=false
# Set token only if skipping auth
#  SHORTCUT_API_TOKEN=xxxxx
