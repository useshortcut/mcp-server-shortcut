{
	"name": "@shortcut/mcp",
	"version": "0.21.0",
	"description": "Shortcut MCP Server",
	"keywords": [
		"shortcut",
		"mcp",
		"modelcontextprotocol"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/useshortcut/mcp-server-shortcut.git"
	},
	"license": "MIT",
	"author": "Shortcut (https://www.shortcut.com)",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"mcp-server-shortcut": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev:http": "bun run src/server-http.ts",
		"format": "biome check --write ./",
		"lint": "biome check ./",
		"prepare": "husky",
		"prod:http": "node dist/server-http.js",
		"prepublish": "bun run build",
		"test": "bun test",
		"ts": "tsc -b"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.25.1",
		"@shortcut/client": "^3.2.0",
		"express": "^4.18.2",
		"pino": "^9.5.0",
		"pino-http": "^10.3.0",
		"zod": "^3.24.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.14",
		"@types/bun": "latest",
		"@types/express": "^4.17.21",
		"bun": "1.3.9",
		"husky": "9.1.7",
		"pino-pretty": "^13.0.0",
		"tsdown": "0.20.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
